APP_NAME="International Student Information Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.railway.app

# Railway MySQL plugin injects these automatically.
# For other hosts, fill these in manually.
DB_HOST=your-mysql-host
DB_PORT=3306
DB_DATABASE=isims
DB_USERNAME=your-db-user
DB_PASSWORD=your-db-password

MAIL_FROM_ADDRESS=no-reply@isims.local
MAIL_FROM_NAME="ISIMS"
